{
  "name": "osop-mcp",
  "displayName": "OSOP — AI Agent Workflow Tools",
  "description": "Validate, render, diff, and assess security risks of OSOP workflow definitions. The standard format for describing and logging AI agent workflows.",
  "version": "0.2.0",
  "author": "OSOP Contributors",
  "license": "Apache-2.0",
  "homepage": "https://osop.ai",
  "repository": "https://github.com/Archie0125/osop-mcp",
  "tags": [
    "workflow",
    "osop",
    "ai-agents",
    "session-logging",
    "validator",
    "mermaid",
    "risk-assessment",
    "execution-log"
  ],
  "tools": [
    "osop.validate",
    "osop.render",
    "osop.report",
    "osop.diff",
    "osop.risk_assess"
  ],
  "runtime": {
    "type": "python",
    "command": "python -m server.main",
    "cwd": ".",
    "env": {}
  },
  "install": {
    "pip": "osop-mcp"
  },
  "config": {
    "claude_desktop": {
      "mcpServers": {
        "osop": {
          "command": "python",
          "args": ["-m", "server.main"],
          "cwd": "/path/to/osop-mcp"
        }
      }
    }
  }
}
